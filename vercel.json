{
  "version": 2,
  "public": true,
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/admin", "destination": "/admin/dashboard.html" },
    { "source": "/proprietaire", "destination": "/proprietaire/index.html" },
    { "source": "/locataire", "destination": "/locataire/index.html" },
    { "source": "/gestionnaire", "destination": "/gestionnaire/index.html" }
  ],
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/css"
        }
      ]
    }
  ]
}
