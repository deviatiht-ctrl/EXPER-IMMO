# Copy this file to .env and fill in your values
# NEVER commit .env to git

# PostgreSQL connection string from Render
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@host:5432/exper_immo

# Secret key for JWT tokens — generate a random string
SECRET_KEY=change-me-to-a-long-random-secret-key

# Full URL of this backend (used for uploaded image URLs)
BASE_URL=https://exper-immo-api.onrender.com

# First admin credentials (used by create_admin.py)
ADMIN_EMAIL=admin@experimmo.com
ADMIN_PASSWORD=Admin@Exp2024!
ADMIN_NAME=Administrateur EXPERIMMO
